# ============================================================================
# India Underwriting Agent — Environment Configuration
#
# INSTRUCTIONS:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in the REQUIRED values below for your workspace
#   3. Run:  cd demo && bash install.sh
# ============================================================================

# ── REQUIRED: Databricks Auth ───────────────────────────────────────────────
# Create a CLI profile first: databricks auth login --host <workspace-url> --profile <name>
DATABRICKS_CONFIG_PROFILE=DEFAULT

# ── REQUIRED: Unity Catalog ─────────────────────────────────────────────────
# Catalog and schema where demo tables will be created.
# You need CREATE TABLE + CREATE FUNCTION permissions on this schema.
UC_CATALOG=my_catalog
UC_SCHEMA=underwriting_demo

# ── REQUIRED: SQL Warehouse ─────────────────────────────────────────────────
# Find in workspace UI: SQL Warehouses > your warehouse > Connection Details > HTTP Path
# The warehouse ID is the last segment of the HTTP path.
DATABRICKS_SQL_WAREHOUSE_ID=

# ── SET AFTER INSTALL ────────────────────────────────────────────────────────
# Genie space ID — auto-filled by install.sh, or set manually after creating via UI
GENIE_SPACE_ID=

# Vector Search index — create manually (see README Step 3), then set here
VS_INDEX=${UC_CATALOG}.${UC_SCHEMA}.rag_idx
VS_ENDPOINT=underwriter_vs_endpoint

# MLflow experiment — auto-filled by quickstart, or set manually
MLFLOW_EXPERIMENT_ID=

# ── OPTIONAL: Customize ─────────────────────────────────────────────────────
# Company name displayed in the UI and agent prompts
COMPANY_NAME=India Life

# LLM model for the orchestrator (any Databricks FMAPI model)
ORCHESTRATOR_MODEL=databricks-claude-sonnet-4-5

# Frontend port (local development only)
CHAT_APP_PORT=3000
CHAT_PROXY_TIMEOUT_SECONDS=300

# MLflow tracking (auto-configured for Databricks)
MLFLOW_TRACKING_URI="databricks"
MLFLOW_REGISTRY_URI="databricks-uc"
